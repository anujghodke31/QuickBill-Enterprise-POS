GOOGLE_CLIENT_ID=your_google_web_client_id
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# --- Security ---
# Set to 'production' on your live server
NODE_ENV=production

# Strong random string (min 32 chars). Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET

# Master admin credentials — stored in env ONLY, never in code
MASTER_ADMIN_USERNAME=REPLACE_WITH_ADMIN_USERNAME
MASTER_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# Comma-separated allowed frontend origins in production
# Example: https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=https://yourdomain.com

# Optional: Firebase Google OAuth
FIREBASE_GOOGLE_CLIENT_ID=your_firebase_google_client_id
