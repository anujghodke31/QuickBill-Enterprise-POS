{
  "name": "quickbill-pos",
  "version": "2.0.0",
  "description": "QuickBill — Enterprise Point of Sale system built with React, Node.js, Express & MongoDB",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev:server": "nodemon server/index.js",
    "dev:client": "cd client && npm run dev",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "cd client && npm run build",
    "seed": "node server/seed.js",
    "test": "jest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "lint:client": "cd client && npm run lint"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "google-auth-library": "^9.15.1",
    "mongoose": "^7.6.3",
    "pdfkit": "^0.17.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "concurrently": "^9.1.2",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.3",
    "globals": "^17.3.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "prettier": "^3.5.1",
    "supertest": "^7.0.0"
  }
}
